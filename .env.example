VITE_APP_TITLE=梦想职业评估 MVP
VITE_USE_STATIC_ROLE_DATA=true
VITE_ENABLE_DEBUG=false

# ── 留资提交 ──────────────────────────────────────────────
# 本地调试：留空，表单数据写入 localStorage（无后端依赖）
# Cloudflare Pages 部署时：设为 /api/bitable，指向同站 Function
VITE_LEAD_WEBHOOK_URL=

# 可选：额外通知 webhook（主提交成功后触发）
# 如已用 FEISHU_BOT_WEBHOOK_URL 在 Function 里推通知，这里留空即可
VITE_LEAD_NOTIFICATION_WEBHOOK_URL=

# ── 飞书接入（服务端变量，仅在 Cloudflare Pages 后台填写，不要加 VITE_ 前缀）──
# 这些变量由 functions/api/bitable.js 读取，前端无法访问
#
# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# FEISHU_BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx   # 多维表格 URL 中的 /base/{这里}
# FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx          # 多维表格 URL 中的 ?table={这里}
# FEISHU_BOT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx  # 可选
#
# 飞书多维表格需包含以下列（列名必须完全一致）：
#   线索类型 / 姓名 / 联系方式 / 目标岗位 / 当前年级 / 留学意向
#   评估得分 / 匹配度标签 / 当前问题 / 提交时间 / 来源页面 / 跟进状态
#   咨询类额外：空档时间 / 咨询主题
#   案例类额外：案例匹配
#   诊断类额外：目标公司类型 / 简历阶段 / 诊断重点 / 简历文件
